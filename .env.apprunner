# AWS App Runner Environment Variables
NODE_ENV=production
DOCKER=true
NEXT_TELEMETRY_DISABLED=1
NEXT_CONFIG_FILE=next.config.apprunner.ts

# Memory optimization
NODE_OPTIONS=--max-old-space-size=6144

# Disable features that might cause build issues
NEXT_PUBLIC_ANALYTICS_VERCEL=false
NEXT_PUBLIC_ANALYTICS_POSTHOG=false
REACT_SCAN_MONITOR_API_KEY=

# Build optimization
ANALYZE=false