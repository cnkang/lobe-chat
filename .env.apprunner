# AWS App Runner Environment Variables
NODE_ENV=production
DOCKER=true
NEXT_TELEMETRY_DISABLED=1

# Memory optimization
NODE_OPTIONS=--max-old-space-size=8192

# Disable features that might cause build issues
NEXT_PUBLIC_ANALYTICS_VERCEL=false
NEXT_PUBLIC_ANALYTICS_POSTHOG=false
REACT_SCAN_MONITOR_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# Build optimization
ANALYZE=false
NEXT_PUBLIC_CLIENT_DB=indexeddb